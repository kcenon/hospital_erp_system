{
  "name": "hospital-erp-system",
  "version": "0.1.0",
  "private": true,
  "description": "Hospital Inpatient Management ERP System",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.53.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=5.0.0 <5.1.7": "5.1.7",
      "minimatch@>=9.0.0 <9.0.6": "9.0.6",
      "minimatch@>=10.0.0 <10.2.1": "10.2.1",
      "systeminformation@<5.31.0": "5.31.0",
      "lodash@<4.17.23": "4.17.23"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2026-27606"
      ]
    }
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
