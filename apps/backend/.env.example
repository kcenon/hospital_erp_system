# =============================================================================
# Hospital ERP Backend - Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://hospital_user:CHANGE_ME@localhost:5432/hospital_erp

# -----------------------------------------------------------------------------
# Redis (Required in production)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT Authentication (Required - minimum 32 characters each)
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_characters_long
JWT_ACCESS_EXPIRATION=1h    # Optional, default: 1h
JWT_REFRESH_EXPIRATION=7d   # Optional, default: 7d

# -----------------------------------------------------------------------------
# Encryption (Required in production)
# Generate with: openssl rand -hex 16
# WARNING: Changing this will make existing encrypted data unreadable
# -----------------------------------------------------------------------------
# ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_encryption_key

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001   # Comma-separated for multiple origins
LOG_LEVEL=info                      # debug | info | warn | error

# -----------------------------------------------------------------------------
# Legacy Database Integration (Optional)
# Enable to connect to existing hospital information system
# All LEGACY_DB_* variables must be set together, or none at all
# -----------------------------------------------------------------------------
# LEGACY_DB_HOST=localhost
# LEGACY_DB_PORT=1433
# LEGACY_DB_USER=CHANGE_ME
# LEGACY_DB_PASSWORD=CHANGE_ME
# LEGACY_DB_NAME=legacy_hospital
# LEGACY_DB_DRIVER=mssql             # mssql | oracle

# -----------------------------------------------------------------------------
# Legacy API Integration (Optional)
# Alternative to direct DB connection
# -----------------------------------------------------------------------------
# LEGACY_API_URL=http://localhost:3001
# LEGACY_API_KEY=CHANGE_ME
# LEGACY_API_TIMEOUT=10000            # Milliseconds
# LEGACY_API_RETRIES=3
